{
  "compilerOptions": {
    "target": "ES2019",
    "module": "none",
    "lib": [
      "ES2019"
    ],
    "types": [
      "google-apps-script"
    ],
    "rootDir": "src",
    "outDir": "build",
    "strict": true,
    "noEmitOnError": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
